{
  "name": "@anubis/core",
  "version": "0.2.0",
  "private": false,
  "description": "Shared runtime + build presets for Anubis World web-component widgets — FX rates, i18n locale picker, Supabase client coordinator, Vite library preset. Pairs with @anubis/ds (visual layer).",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./vite-preset": {
      "types": "./vite-preset.d.ts",
      "import": "./vite-preset.mjs"
    }
  },
  "files": ["dist", "vite-preset.mjs", "vite-preset.d.ts"],
  "scripts": {
    "build": "tsc -p tsconfig.json"
  },
  "peerDependencies": {
    "@preact/preset-vite": "^2.10.5",
    "@supabase/supabase-js": "^2.105.1",
    "vite": "^8.0.0"
  },
  "devDependencies": {
    "@supabase/supabase-js": "^2.105.1",
    "typescript": "~5.6.0"
  }
}
